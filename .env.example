# Comma-separated proxy URLs (empty = direct connection)
PROXY_LIST=

SENTIMENT_LOOKBACK_DAYS=14

OUTPUT_PATH=spectre_analysis.json

DRY_RUN=false

# Optional: async Redis queue (arq). Default in-process execution.
USE_TASK_QUEUE=false
REDIS_URL=redis://localhost:6379/0
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=120

# HTTP defaults (override as needed)
HTTP_TIMEOUT_SECONDS=30.0

# Rotating User-Agent pool (comma-separated)
USER_AGENT_POOL=Mozilla/5.0 (compatible; Spectre/0.1)

# SEC EDGAR identity (required by edgartools for API courtesy)
EDGAR_IDENTITY=YourName your.email@example.com
